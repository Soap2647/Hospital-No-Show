@inherits LayoutComponentBase
@inject AuthApiService AuthService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudSnackbarProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudPopoverProvider />

<MudLayout>
    <!-- App Bar -->
    <MudAppBar Elevation="0" Fixed="true"
               Style="@(_isDarkMode
                    ? "background:#0D1B2A;border-bottom:1px solid rgba(220,50,50,0.35);"
                    : "background:#0D1B2A;border-bottom:1px solid rgba(255,255,255,0.12);")">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />

        <div class="d-flex align-center gap-2 ml-1">
            <!-- Sağlık Bakanlığı Logosu -->
            <img src="images/logo.png" style="width:38px;height:38px;object-fit:contain;" alt="Logo" />
            <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:-.3px;color:#fff;">
                Hastane No-Show Sistemi
            </MudText>
        </div>

        <MudSpacer />

        @if (_session != null)
        {
            <div class="d-flex align-center gap-1">
                <div class="d-none d-sm-flex flex-column align-end" style="line-height:1.2">
                    <MudText Typo="Typo.body2" Style="font-weight:600;color:rgba(255,255,255,.95)">
                        @_session.FullName
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.6)">
                        @_session.PrimaryRole
                    </MudText>
                </div>
                <MudAvatar Style="background:rgba(198,40,40,0.8);color:#fff;font-weight:700;width:34px;height:34px;font-size:.82rem;margin-left:8px;">
                    @(_session.FullName.FirstOrDefault().ToString())
                </MudAvatar>

                <!-- Koyu Mod Toggle -->
                <MudTooltip Text="@(_isDarkMode ? "Açık Mod" : "Koyu Mod")">
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                                   Color="Color.Inherit"
                                   Size="Size.Small"
                                   OnClick="ToggleDarkModeAsync" />
                </MudTooltip>

                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="LogoutAsync" />
            </div>
        }
        else
        {
            <!-- Giriş yapmamışken de toggle göster -->
            <MudTooltip Text="@(_isDarkMode ? "Açık Mod" : "Koyu Mod")">
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="ToggleDarkModeAsync" />
            </MudTooltip>
        }
    </MudAppBar>

    <!-- Navigation Drawer -->
    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Style="@(_isDarkMode ? "background:#111C2D;border-right:1px solid rgba(255,255,255,.08);" : "background:#fff;border-right:1px solid #e2e4ea;")">

        <MudNavMenu Class="px-2 pt-2">
            @if (_session?.IsAdmin == true)
            {
                <MudText Typo="Typo.overline" Class="px-3 pt-3 pb-1"
                         Style="@($"color:{(_isDarkMode ? "#ef5350" : "#C62828")};font-size:.65rem;letter-spacing:.1em")">
                    YÖNETİM
                </MudText>
                <MudNavLink Href="/admin/dashboard" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Dashboard">
                    Dashboard
                </MudNavLink>
            }

            @if (_session?.IsDoctor == true)
            {
                <MudText Typo="Typo.overline" Class="px-3 pt-3 pb-1"
                         Style="@($"color:{(_isDarkMode ? "#ef5350" : "#C62828")};font-size:.65rem;letter-spacing:.1em")">
                    DOKTOR PANELİ
                </MudText>
                <MudNavLink Href="/doctor/panel" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.CalendarToday">
                    Günlük Randevular
                </MudNavLink>
            }

            @if (_session?.IsPatient == true)
            {
                <MudText Typo="Typo.overline" Class="px-3 pt-3 pb-1"
                         Style="@($"color:{(_isDarkMode ? "#ef5350" : "#C62828")};font-size:.65rem;letter-spacing:.1em")">
                    HASTA PANELİ
                </MudText>
                <MudNavLink Href="/patient/panel" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Person">
                    Panelim
                </MudNavLink>
            }
        </MudNavMenu>

        <MudSpacer />
        <div class="px-4 py-3" style="@($"border-top:1px solid {(_isDarkMode ? "rgba(255,255,255,.08)" : "#e2e4ea")}")">
            <MudText Typo="Typo.caption" Style="@($"color:{(_isDarkMode ? "#546e8a" : "#bbb")}")">
                v1.0 · 2026
            </MudText>
        </div>
    </MudDrawer>

    <!-- Main Content -->
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-md-6">
            <ErrorBoundary>
                <ChildContent>@Body</ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="mt-4" Icon="@Icons.Material.Filled.BugReport">
                        <MudText Typo="Typo.subtitle2">Beklenmeyen bir hata oluştu.</MudText>
                        <MudText Typo="Typo.caption">@ex.Message</MudText>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private UserSession? _session;

    private const string DarkModeKey = "hnshow_darkmode";

    // ── Tema Tanımı ──────────────────────────────────────────────────────────

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            // Koyu lacivert primary, kırmızı secondary
            Primary         = "#0D1B2A",
            PrimaryDarken   = "#060e18",
            PrimaryLighten  = "#1A2D42",
            Secondary       = "#C62828",
            SecondaryDarken = "#8B0000",
            AppbarBackground = "#0D1B2A",
            Background      = "#F4F5F8",
            Surface         = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText      = "#0D1B2A",
            Success         = "#2e7d32",
            Warning         = "#e65100",
            Error           = "#C62828",
            Info            = "#1565C0",
            TableLines      = "#f0f0f0",
            OverlayDark     = "rgba(0,0,0,0.5)"
        },
        PaletteDark = new PaletteDark
        {
            // Softer "medical slate" dark mode
            Primary         = "#4A90E2",      // Softer, inviting blue
            PrimaryDarken   = "#357ABD",
            PrimaryLighten  = "#73A8E8",
            Secondary       = "#E64A45",      // Slightly softer red for accents/alerts
            SecondaryDarken = "#C4322D",
            AppbarBackground = "#151C26",     // Deep slate instead of pitch black
            Background      = "#0E141B",      // Very dark slate for main background
            Surface         = "#1A2332",      // Elevated slate for cards (less harsh than #111)
            DrawerBackground = "#151C26",
            DrawerText      = "#E8EAF6",
            Success         = "#388E3C",      // Muted green
            Warning         = "#F57C00",      // Muted orange
            Error           = "#E64A45",
            Info            = "#4A90E2",
            TextPrimary     = "#E0E6ED",      // Off-white for better eye comfort
            TextSecondary   = "#94A3B8",      // Soft slate-gray for subtitles
            TableLines      = "rgba(255,255,255,0.08)",
            OverlayDark     = "rgba(0,0,0,0.6)"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px",
            DrawerWidthLeft     = "248px"
        }
    };

    // ── Yaşam Döngüsü ───────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _session = await AuthService.GetCurrentSessionAsync();

        // Kaydedilmiş dark mode tercihini yükle
        try
        {
            _isDarkMode = await LocalStorage.GetItemAsync<bool>(DarkModeKey);
        }
        catch { _isDarkMode = false; }
    }

    private async Task ToggleDarkModeAsync()
    {
        _isDarkMode = !_isDarkMode;
        await LocalStorage.SetItemAsync(DarkModeKey, _isDarkMode);
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Snackbar.Add("Çıkış yapıldı.", Severity.Info);
        Nav.NavigateTo("/login");
    }
}
