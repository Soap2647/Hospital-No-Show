@* Dairesel risk göstergesi bileşeni *@

<div class="risk-gauge" style="width:@(Size)px;height:@(Size)px;position:relative;">
    <svg viewBox="0 0 36 36" style="transform:rotate(-90deg)">
        <!-- Arka plan çemberi -->
        <circle cx="18" cy="18" r="15.9"
                fill="none" stroke="#e0e0e0" stroke-width="3" />
        <!-- Risk çemberi -->
        <circle cx="18" cy="18" r="15.9"
                fill="none"
                stroke="@GetColor()"
                stroke-width="3"
                stroke-dasharray="@($"{Score * 100:F1} {100 - Score * 100:F1}")"
                stroke-linecap="round" />
    </svg>
    <div class="gauge-label" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
        <span style="font-size:@(Size * 0.22)px;font-weight:700;color:@GetColor()">
            @($"{Score * 100:F0}")
        </span>
        <span style="font-size:@(Size * 0.14)px;color:#9e9e9e;display:block;margin-top:-2px">%</span>
    </div>
</div>

@code {
    [Parameter] public double Score { get; set; }
    [Parameter] public int Size { get; set; } = 70;

    private string GetColor() => Score switch
    {
        > 0.80 => "#f44336",
        > 0.60 => "#ff9800",
        > 0.30 => "#2196f3",
        _ => "#4caf50"
    };
}
